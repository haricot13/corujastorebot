# ==============================================================================
# CONFIGURAÇÃO DE HOSPEDAGEM DISCLOUD - CORUJA STORE BOT
# Veja a documentação em: https://docs.discloudbot.com
# ==============================================================================

# ID: Define o subdomínio do seu painel na Discloud se TYPE for "site".
# Exemplo: corujastore.discloud.app
ID=corujastore

# TYPE: Deve ser "site" para que a Discloud abra as portas HTTP e libere a URL.
# Isso permite que você acesse o Painel Web (Interface Gráfica do WhatsApp).
TYPE=site

# MAIN: O arquivo principal que inicia o servidor.
# Como o projeto compila o TypeScript para JavaScript nativo, apontamos para dist/server.cjs
MAIN=dist/server.cjs

# RAM: Quantidade de memória RAM a ser alocada (em Megabytes).
# Recomendamos pelo menos 512MB ou 1024MB devido ao motor Baileys/WhatsApp e processamento do bot.
RAM=512

# AUTORESTART: Define se o bot deve reiniciar automaticamente caso caia ou ocorra um erro.
AUTORESTART=true

# VERSION: Versão do Node.js de execução. "latest" roda a última versão estável LTS.
VERSION=latest

# BUILD: Comando executado após a instalação de dependências para compilar os assets do React e esbuild.
BUILD=npm run build
